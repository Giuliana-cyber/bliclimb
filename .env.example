# ============================================
# OpenAI (chat + planes + embeddings)
# ============================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Vector store antiguo (PDFs). Lo migraremos a pgvector en Supabase.
OPENAI_VECTOR_STORE_ID=

# ============================================
# Supabase (auth + DB + pgvector + storage)
# ============================================
# Project Settings → API en Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# OJO: service_role NUNCA al cliente. Solo para webhooks y jobs server-side.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3003
REQUIRE_SUBSCRIPTION=false

# ============================================
# Stripe (proveedor activo — $249 MXN/año + 30 días trial)
# ============================================
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Dashboard → Developers → Webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Dashboard → Products → BilClimb Annual → Pricing
# El trial de 30 días vive en el Price (trial_period_days: 30).
STRIPE_PRICE_ID=price_1TjA6IBfS6NSxetgqzfZsoWm

# ============================================
# DEPRECATED — Mercado Pago (cuenta bloqueada por políticas)
# El código sigue en lib/billing/mercado-pago.ts marcado como legacy.
# Cuando confirmemos que Stripe está estable, se borra todo.
# ============================================
# MERCADO_PAGO_ACCESS_TOKEN=
# MERCADO_PAGO_SUBSCRIPTION_AMOUNT=
# MERCADO_PAGO_CURRENCY=
# MERCADO_PAGO_USE_SANDBOX=
# MERCADO_PAGO_WEBHOOK_SECRET=

# ============================================
# Cookies y secretos
# ============================================
SUBSCRIPTION_COOKIE_SECRET=

# ============================================
# Rate limiting (opcional — Upstash Redis serverless)
# Si no se setean, cae a in-memory por instancia.
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# DEPRECATED — Clerk (lo removeremos cuando migremos auth a Supabase)
# ============================================
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
