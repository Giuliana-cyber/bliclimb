# ============================================
# OpenAI (chat + planes + embeddings)
# ============================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Vector store antiguo (PDFs). Lo migraremos a pgvector en Supabase.
OPENAI_VECTOR_STORE_ID=

# ============================================
# Supabase (auth + DB + pgvector + storage)
# ============================================
# Project Settings → API en Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# OJO: service_role NUNCA al cliente. Solo para webhooks y jobs server-side.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3003
REQUIRE_SUBSCRIPTION=false

# ============================================
# Mercado Pago (LATAM)
# ============================================
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_SUBSCRIPTION_AMOUNT=1
MERCADO_PAGO_CURRENCY=USD
MERCADO_PAGO_USE_SANDBOX=true
# Secret del panel "Webhooks" de Mercado Pago — usado para verificar firmas
MERCADO_PAGO_WEBHOOK_SECRET=

# ============================================
# Stripe (global)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=

# ============================================
# Cookies y secretos
# ============================================
SUBSCRIPTION_COOKIE_SECRET=

# ============================================
# Rate limiting (opcional — Upstash Redis serverless)
# Si no se setean, cae a in-memory por instancia.
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# DEPRECATED — Clerk (lo removeremos cuando migremos auth a Supabase)
# ============================================
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
